# Copy to ~/.config/hermes-studio/account-gateway.env and replace every value.
# Keep this file private: it grants access to the Hermes API behind the gateway.

HERMES_STUDIO_ACCOUNT_HOST=0.0.0.0
HERMES_STUDIO_ACCOUNT_PORT=8650
HERMES_STUDIO_DATA_DIR=/home/your-linux-user/.local/share/hermes-studio
HERMES_STUDIO_SETUP_CODE=replace-with-a-long-random-pairing-code