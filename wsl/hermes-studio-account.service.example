[Unit]
Description=Hermes Studio Account Gateway
After=hermes-gateway.service
Wants=hermes-gateway.service

[Service]
Type=simple
WorkingDirectory=%h/hermes-studio
EnvironmentFile=%h/.config/hermes-studio/account-gateway.env
ExecStart=%h/hermes-studio/.venv/bin/python %h/hermes-studio/wsl/account_gateway.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target